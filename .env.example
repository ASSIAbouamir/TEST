# ============================================================
# Legal AI Automation — Configuration complète
# Copiez ce fichier en .env et remplissez vos valeurs
# ============================================================

# ----------------------------
# LlamaParse (parsing PDF/DOCX)
# ----------------------------
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# ----------------------------
# Groq (modèle LLM principal)
# ----------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ----------------------------
# OpenRouter (LLM alternatif)
# ----------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ----------------------------
# OpenAI (embeddings)
# ----------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ----------------------------
# WhyHow Knowledge Graph
# ----------------------------
WHYHOW_API_KEY=your_whyhow_api_key_here
WHYHOW_API_URL=https://api.whyhow.ai

# ----------------------------
# Dossiers (chemins relatifs)
# ----------------------------
INPUT_DIR=data/input
PARSED_DIR=data/parsed
ARCHIVE_DIR=data/archive

# ----------------------------
# Entreprise (pour les alertes)
# ----------------------------
# Nom affiché dans les rapports et emails
COMPANY_NAME=Mon Entreprise SARL

# ----------------------------
# Veille Internet
# ----------------------------
# Intervalle entre deux scans automatiques (en heures)
MONITOR_INTERVAL_HOURS=6
# Nombre minimum de mots-clés thématiques pour considérer une alerte "critique"
ALERT_MIN_TOPICS=1

# ----------------------------
# Alertes Email (SMTP)
# ----------------------------
# Destinataires des alertes (séparés par des virgules)
ALERT_EMAIL_TO=directeur@monentreprise.com,juridique@monentreprise.com
# Expéditeur
ALERT_EMAIL_FROM=legal-ai@monentreprise.com
# Serveur SMTP (ex: smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=legal-ai@monentreprise.com
# Pour Gmail : utiliser un "mot de passe d'application" (App Password)
SMTP_PASSWORD=your_smtp_app_password_here

# ----------------------------
# RAG — Paramètres de retrieval
# ----------------------------
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_KEYWORD=10
TOP_K_FINAL=5

# ----------------------------
# Agent — Paramètres
# ----------------------------
MAX_RECURSION_DEPTH=5
MAX_CONTEXT_TOKENS=8000
SIMILARITY_THRESHOLD=0.7

# ----------------------------
# Traitement des documents
# ----------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
DEFAULT_LANGUAGE=fr

# ----------------------------
# Graphes (auto-remplis)
# ----------------------------
LEXICAL_GRAPH_ID=
DEFINITIONS_GRAPH_ID=
