# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI Configuration (for embeddings only)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# WhyHow Knowledge Graph Studio Configuration
WHYHOW_API_KEY=your_whyhow_api_key_here
WHYHOW_API_URL=https://api.whyhow.ai

# Reducto Configuration (optional)
REDUCTO_API_KEY=your_reducto_api_key_here

# Graph Configuration (will be auto-populated)
LEXICAL_GRAPH_ID=
DEFINITIONS_GRAPH_ID=

# Retrieval Configuration
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_KEYWORD=10
TOP_K_FINAL=5

# Agent Configuration
MAX_RECURSION_DEPTH=5
MAX_CONTEXT_TOKENS=8000
SIMILARITY_THRESHOLD=0.7

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
